# ─────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────

# Email service API key — server-side only, NEVER prefix with NEXT_PUBLIC_
EMAIL_API_KEY=your_email_api_key_here

# Recipient email for contact form submissions — server-side only
CONTACT_EMAIL_TO=owner@yourdomain.com

# SMTP settings (if using nodemailer instead of an API service)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password

# Public site config — non-sensitive only, safe to expose to browser
NEXT_PUBLIC_SITE_URL=http://localhost:3000
